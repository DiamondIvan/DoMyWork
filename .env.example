# Telegram (Pyrogram)
# You can keep your existing `api_id = ...` / `api_hash = ...` format too.
# Recommended standard .env format is KEY=value:
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional: if you use a session string instead of api_id/api_hash
PYROGRAM_SESSION_NAME=my_account
PYROGRAM_SESSION_STRING=

# Google OAuth (Gmail + Calendar)
# For Expo Go, redirect URI usually looks like:
#   https://auth.expo.io/@YOUR_EXPO_USERNAME/DoMyWork
# IMPORTANT: The redirect URI must match EXACTLY everywhere:
# - Google Cloud Console OAuth client "Authorized redirect URIs"
# - Expo app redirectUri (computed by expo-auth-session, or EXPO_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI)
# - Backend GOOGLE_OAUTH_REDIRECT_URI used during token exchange
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Expo app config (safe to include in the app bundle)
# Client ID is public (not a secret). Do NOT put client secret in EXPO_PUBLIC vars.
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# Your deployed Firebase Functions base URL (region + project id)
# Example:
#   https://asia-southeast1-domywork-df38f.cloudfunctions.net
EXPO_PUBLIC_FUNCTIONS_BASE_URL=
EXPO_PUBLIC_DEFAULT_USER_ID=
EXPO_PUBLIC_CHAT_API_URL=

# Your FastAPI backend base URL (Telegram auth/chats endpoints)
# Example:
#   http://10.167.66.131:8000
EXPO_PUBLIC_TELEGRAM_API_URL=

# Optional: force the redirect URI used by expo-auth-session.
# If omitted, the app will compute one (proxy redirect in Expo Go).
EXPO_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=

# Firebase Admin SDK (for scheduler_bot.py to enqueue Firestore docs)
# Either set GOOGLE_APPLICATION_CREDENTIALS or FIREBASE_SERVICE_ACCOUNT_KEY_PATH
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=

# AI (Gemini)
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
